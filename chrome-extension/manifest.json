{
  "manifest_version": 3,
  "name": "LLM Translator",
  "version": "1.0",
  "description": "Translate text using LLM with context awareness.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.groq.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "css": ["css/content.css"]
    }
  ]
}
